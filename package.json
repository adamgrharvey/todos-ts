{
  "name": "todos-ts",
  "version": "1.0.0",
  "description": "A practice Todos app using Vite, Fastify, Mongoose, and React",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --project tsconfig.server.json && vite build",
    "build:client": "vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "node dist/index.js",
    "start:server": "tsx server/index.ts",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamgrharvey/todos-ts.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/adamgrharvey/todos-ts/issues"
  },
  "homepage": "https://github.com/adamgrharvey/todos-ts#readme",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.12.2",
    "fastify": "^5.6.0",
    "mongoose": "^8.18.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "uuid": "^13.0.0",
    "vite": "^7.1.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.5.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
